{
  "name": "github_unique_visitors_14d",
  "description": "GitHub unique page visitors for dvquy13/qrec over the last 14 days",
  "auth": {
    "type": "api_key",
    "env": "GITHUB_TOKEN",
    "format": "bearer"
  },
  "request": {
    "url": "https://api.github.com/repos/dvquy13/qrec/traffic/views",
    "method": "GET"
  },
  "extract": {
    "type": "jsonpath",
    "path": "uniques",
    "cast": "int"
  },
  "validate": { "min": 0, "max": 100000 }
}
