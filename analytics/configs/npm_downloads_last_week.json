{
  "name": "npm_downloads_last_week",
  "description": "npm downloads for @dvquys/qrec in the last 7 days",
  "auth": { "type": "none" },
  "request": {
    "url": "https://api.npmjs.org/downloads/point/last-week/%40dvquys%2Fqrec",
    "method": "GET"
  },
  "extract": {
    "type": "jsonpath",
    "path": "downloads",
    "cast": "int"
  },
  "validate": { "min": 0, "max": 1000000 }
}
