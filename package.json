{
  "name": "@dvquys/qrec",
  "version": "0.6.6",
  "description": "Purpose-built session recall engine — persistent daemon with BM25 + vector hybrid search",
  "bin": {
    "qrec": "plugin/scripts/qrec-cli.js"
  },
  "files": [
    "plugin/scripts/qrec.cjs",
    "plugin/scripts/qrec-mcp.cjs",
    "plugin/scripts/qrec-cli.js",
    "plugin/scripts/qrec-mcp.js",
    "plugin/scripts/bun-finder.js",
    "plugin/scripts/postinstall.js",
    "plugin/.claude-plugin",
    "plugin/hooks",
    "plugin/skills",
    "plugin/package.json",
    "ui",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node plugin/scripts/postinstall.js",
    "dev": "bun run src/cli.ts",
    "build": "node scripts/build.js",
    "release": "bash scripts/release.sh",
    "smoke-test": "bash scripts/smoke-test.sh",
    "check-package": "bash scripts/check-package.sh",
    "test": "QREC_EMBED_PROVIDER=stub bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
