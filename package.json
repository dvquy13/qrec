{
  "name": "@dvquys/qrec",
  "version": "0.8.4",
  "description": "Purpose-built session recall engine — persistent daemon with BM25 + vector hybrid search",
  "license": "MIT",
  "author": "dvquy13",
  "repository": {
    "type": "git",
    "url": "https://github.com/dvquy13/qrec.git"
  },
  "homepage": "https://github.com/dvquy13/qrec#readme",
  "bugs": {
    "url": "https://github.com/dvquy13/qrec/issues"
  },
  "keywords": [
    "claude-code",
    "session-recall",
    "semantic-search",
    "embeddings",
    "sqlite",
    "llm",
    "productivity"
  ],
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=18.0.0"
  },
  "bin": {
    "qrec": "plugin/scripts/qrec-cli.js"
  },
  "files": [
    "plugin/scripts/qrec.cjs",
    "plugin/scripts/qrec-cli.js",
    "plugin/scripts/bun-finder.js",
    "plugin/scripts/postinstall.js",
    "plugin/.claude-plugin",
    "plugin/hooks",
    "plugin/skills",
    "plugin/package.json",
    "ui",
    "public",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node plugin/scripts/postinstall.js",
    "dev": "bun run src/cli.ts",
    "build": "node scripts/build.js",
    "release": "bash scripts/release.sh",
    "smoke-test": "bash scripts/smoke-test.sh",
    "check-package": "bash scripts/check-package.sh",
    "test": "QREC_EMBED_PROVIDER=stub bun test"
  },
  "dependencies": {
    "citty": "^0.2.1",
    "node-llama-cpp": "3.17.1",
    "sqlite-vec": "^0.1.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "esbuild": "^0.27.3",
    "typescript": "^5.0.0"
  },
  "trustedDependencies": [
    "node-llama-cpp"
  ]
}
